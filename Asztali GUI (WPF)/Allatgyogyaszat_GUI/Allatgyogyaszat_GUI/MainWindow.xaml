<Window x:Class="Allatgyogyaszat_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Allatgyogyaszat_GUI"
        mc:Ignorable="d"
        Title="Állatgyógyászat" Height="469" Width="588">
    <Grid Height="434" VerticalAlignment="Bottom">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="115*"/>
            <ColumnDefinition Width="179*"/>
        </Grid.ColumnDefinitions>
        <ListBox Name="listbox" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="20,36,0,0" Grid.Column="1"/>
        <Label Content="Keresés név alapján:" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>
        <TextBox Name="txtName" HorizontalAlignment="Left" Margin="10,36,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" TextChanged="txtName_TextChanged"/>
        <Label Content="Keresés kerület alapján" HorizontalAlignment="Left" Margin="10,75,0,0" VerticalAlignment="Top"/>
        <ComboBox Name="comboKerulet" HorizontalAlignment="Left" Margin="15,106,0,0" VerticalAlignment="Top" Width="120" SelectionChanged="comboKerulet_SelectionChanged"/>
        <Button Content="Adatok Frissítése" HorizontalAlignment="Left" Margin="22,9,0,0" VerticalAlignment="Top" Click="Button_Click" Grid.Column="1"/>
        <CheckBox Content="Új adat" Margin="10,133,348,282" Grid.ColumnSpan="2" Checked="CheckBox_Checked"/>
        <GroupBox Name="groupUj" Header="Új adat megadása" Margin="10,157,10,148" Visibility="Collapsed">
            <Canvas Margin="0,0,-2,0">
                <TextBox Name="txtAdatsor" HorizontalAlignment="Left" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="180" Canvas.Top="10" Canvas.Left="10" Height="61"/>
                <Button Content="Új adat felvétele" Canvas.Left="10" Canvas.Top="76" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            </Canvas>
        </GroupBox>


    </Grid>
</Window>
