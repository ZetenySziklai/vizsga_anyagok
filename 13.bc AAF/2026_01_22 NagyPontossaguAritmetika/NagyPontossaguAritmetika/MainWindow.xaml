<Window x:Class="NagyPontossaguAritmetika.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NagyPontossaguAritmetika"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Name="mainGrid">
        <TextBox Name="szam1_text" HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" TextChanged="szam1_text_TextChanged"/>
        <TextBox Name="szam2_text" HorizontalAlignment="Left" Margin="10,33,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <Button Content="Szamol" HorizontalAlignment="Left" Margin="144,19,0,0" VerticalAlignment="Top" Height="23" Width="100" Click="Button_Click"/>
        <Label Name="eredmeny_label" Content="Label" HorizontalAlignment="Left" Margin="10,56,0,0" VerticalAlignment="Top" Width="120" Height="30"/>
        <Button Content="Szinez" HorizontalAlignment="Left" Margin="10,91,0,0" VerticalAlignment="Top" Height="23" Width="91" Click="Button_Click_1" MouseMove="Button_MouseMove" MouseLeave="Button_EgerLevetel"/>
        <RadioButton Content="RadioButton" HorizontalAlignment="Left" Margin="105,64,0,0" VerticalAlignment="Top" Checked="RadioButton_Checked"/>
        <Button Name="general_btn" Content="Generálás" HorizontalAlignment="Left" Margin="9,119,0,0" VerticalAlignment="Top" Width="92" Click="Button_Click_2"/>

        <!--<Slider Name="slider1" HorizontalAlignment="Left" Margin="10,157,0,0" VerticalAlignment="Top" Width="307" ValueChanged="slider1_ValueChanged" Maximum="300"/>-->
        <Slider Name="slider1" HorizontalAlignment="Left" Margin="10,157,0,0" VerticalAlignment="Top" Width="234" Maximum="300"/>
        <TextBlock Name="txtBlock" HorizontalAlignment="Left" Margin="10,191,0,0" TextWrapping="Wrap" Text="{Binding ElementName=slider1, Path=Value}" VerticalAlignment="Top" Height="14" Width="25"/>
        <TextBox HorizontalAlignment="Left" Margin="9,217,0,0" TextWrapping="Wrap" 
          Text="{Binding ElementName=slider1, Path=Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Height="22" Width="97"/>
        <Button Content="Binding törlése" Click="Button_Click_3" HorizontalAlignment="Left" Margin="9,244,0,0" VerticalAlignment="Top" Height="34" Width="109"/>
        <Slider Name="sliderWidth" HorizontalAlignment="Left" Margin="527,19,0,0" VerticalAlignment="Top" Width="191" Maximum="200" Minimum="20"/>
        <Slider Name="sliderHeight" HorizontalAlignment="Left" Margin="396,145,0,0" VerticalAlignment="Top" Width="178" RenderTransformOrigin="0.5,0.5" Maximum="200" Minimum="20">
            <Slider.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="90.281"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Slider.RenderTransform>
        </Slider>
        <Rectangle HorizontalAlignment="Left" Height="{Binding ElementName=sliderHeight, Path=Value}" Margin="508,51,0,0" Stroke="Black" VerticalAlignment="Top" Width="{Binding ElementName=sliderWidth, Path=Value}"/>

    </Grid>
</Window>
