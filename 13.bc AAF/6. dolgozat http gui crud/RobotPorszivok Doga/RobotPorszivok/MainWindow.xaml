<Window x:Class="RobotPorszivok.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RobotPorszivok"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="800">
    <Window.DataContext>
        <local:AdatokViewModel x:Name="viewModel"/>
    </Window.DataContext>
    
    <Grid Margin="0,0,0,0">
        <TabControl>
            <TabItem Header="RobotPorszivok">
                <StackPanel>
                    <Button Content="Adatok frissítése" Margin="10" Click="RobotPorszivoFrissites_Cick"/>
                    <GroupBox x:Name="UjAdatR" Header="Új porszívó hozzáadása" Margin="0,0,0,2">
                        <StackPanel Margin="5">
                            <Label Content="Márka:"/>
                            <TextBox />
                            <Label Content="Típus:"/>
                            <TextBox />
                            <Label Content="Teljesitmeny:"/>
                            <TextBox />
                            <Label Content="Ár:"/>
                            <TextBox/>
                            <Button Content="Mentés" Margin="0,10,0,0" />
                        </StackPanel>
                    </GroupBox>
                    <DataGrid ItemsSource="{Binding RobotPorszivok}" AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Márka" Binding="{Binding Marka}" Width="*"/>
                            <DataGridTextColumn Header="Típus" Binding="{Binding Tipus}" Width="*"/>
                            <DataGridTextColumn Header="Teljesítmény" Binding="{Binding Teljesitmeny}" Width="*"/>
                            <DataGridTextColumn Header="Ár" Binding="{Binding Ar}" Width="*"/>
                            <DataGridTemplateColumn Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                            <Button/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>

                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </TabItem>
            <TabItem Header="Értékelések">
                <StackPanel>
                    <Button Content="Adatok frissítése" Margin="10" Click="ErtekelesFrissites_Click" />
                    <GroupBox x:Name="UjAdatE" Header="Új értékelés hozzáadása" Margin="0,0,0,2">
                        <StackPanel Margin="5">
                            <StackPanel Margin="5" Orientation="Horizontal">
                                <Label Content="Robot_Id:"/>
                                <TextBox Width="400"/>
                            </StackPanel>
                            <StackPanel Margin="5" Orientation="Horizontal">
                                <Label Content="Felhasznaló Neve:"/>
                                <TextBox  Width="400"/>
                            </StackPanel>
                            <StackPanel Margin="5" Orientation="Horizontal">
                                <Label Content="Csillagszam:"/>
                                <TextBox Width="400"/>
                            </StackPanel>
                            <StackPanel Margin="5" Orientation="Horizontal">
                                <Label Content="Szoveg:"/>
                                <TextBox Width="400"/>
                            </StackPanel>
                            <Button Content="Mentés" Margin="0,10,0,0" />
                        </StackPanel>
                    </GroupBox>
                    <DataGrid ItemsSource="{Binding Ertekelesek}" Height="200" AutoGenerateColumns="False" CanUserAddRows="False" ScrollViewer.CanContentScroll="True" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <!--<DataGridTextColumn Header="Robot_Id" Binding="{Binding RobotId}" Width="*"/>-->
                            <DataGridTextColumn Header="Márka" Binding="{Binding Marka}" Width="*"/>
                            <DataGridTextColumn Header="Felhasználónév" Binding="{Binding Felhasznalonev}" Width="*"/>
                            <DataGridTextColumn Header="Csillagszam" Binding="{Binding Csillagszam}" Width="*"/>
                            <DataGridTextColumn Header="Szöveg" Binding="{Binding Szoveg}" Width="*"/>
                            <DataGridTemplateColumn Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                            <Button/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                    
                            </DataGridTemplateColumn>
                
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
