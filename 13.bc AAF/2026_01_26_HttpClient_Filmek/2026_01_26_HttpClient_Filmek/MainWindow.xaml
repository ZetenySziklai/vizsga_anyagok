<Window x:Class="_2026_01_26_HttpClient_Filmek.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_2026_01_26_HttpClient_Filmek"
        mc:Ignorable="d"        
        Title="MainWindow" Height="600" Width="800">
    <Window.DataContext>
        <local:FilmekViewModel />
    </Window.DataContext>
    <StackPanel>
        <GroupBox Margin="10">
            <StackPanel>
                <Label Content="Cím"/>
                <TextBox x:Name="TxtCim"/>
                <Label Content="Hossz"/>
                <TextBox x:Name="TxtHossz"/>
                <Label Content="Értékelés"/>
                <TextBox x:Name="TxtErtekeles"/>
                <Button x:Name="BtnMentes" Content="Mentés" Click="Button_Click" Margin="10"/>
                <Button x:Name="BtnModositas" Content="Modosítás" Click="Button_Click_Modositas" Margin="10"/>
            </StackPanel>
        </GroupBox>
        <StackPanel Orientation="Horizontal" Margin="10">
            <TextBox Name="TxtDeleteCim" Text="" Width="50" Margin="10,0"/>
            <Button Name="BtnDelete" Content="Törlés" Click="DeleteButton_Click"/>
        </StackPanel>
        <!--<DataGrid Name="dataGrid" ItemsSource="{Binding Filmek}" SelectionUnit="FullRow" SelectionChanged="DataGrid_SelectionChanged"/>-->
        <DataGrid Name="DataGrid_Filmek" ItemsSource="{Binding Filmek}" AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Cím" Binding="{Binding Cim}" Width="*"/>
                <DataGridTextColumn Binding="{Binding Hossz}" Header="Hossz" Width="*"/>
                <DataGridTextColumn Binding="{Binding Ertekeles}" Header="Értékelés" Width="*"/>
                <DataGridTemplateColumn Header="Műveletek" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Szerkesztés" Click="BtnEdit_Click"/>
                                <Button Content="Töröl" Click="BtnDelete_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

    </StackPanel>
</Window>
